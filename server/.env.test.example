# Скопируйте в .env.test и укажите тестовую БД (не используйте продакшен).
# Интеграционные тесты: npm run test:integration

TEST_DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/tanks_test

# Если не задано, для интеграции подставится безопасное значение из setup-env.ts
JWT_SECRET=jest-integration-secret-key-min-32-chars!!
